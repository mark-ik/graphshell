{
  "version": 1,
  "packs": [
    {
      "id": "docs-parity",
      "description": "Active-doc stale-term guard for edge model, lifecycle wording, and runtime namespace policy",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "design_docs/DOC_README.md",
        "design_docs/graphshell_docs/technical_architecture/",
        "design_docs/graphshell_docs/implementation_strategy/",
        "design_docs/graphshell_docs/design/",
        "design_docs/graphshell_docs/testing/",
        "scripts/dev/docs-parity.ps1",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "pwsh -NoProfile -File scripts/dev/docs-parity.ps1"
      ]
    },
    {
      "id": "camera-lock",
      "description": "Camera fit-lock reducer + input + orchestration modal passthrough",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "graph_app.rs",
        "input/mod.rs",
        "render/mod.rs",
        "shell/desktop/ui/gui_orchestration.rs",
        "shell/desktop/ui/gui_orchestration_tests.rs",
        "shell/desktop/tests/scenarios/input_routing.rs"
      ],
      "commands": [
        "cargo test camera_fit_lock",
        "cargo test --features diagnostics modal_is_active"
      ]
    },
    {
      "id": "focus-routing",
      "description": "Host/UI focus routing shortcuts and workbench focus cycle",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/host/headed_window.rs",
        "shell/desktop/ui/gui.rs",
        "shell/desktop/ui/gui_update_coordinator.rs",
        "shell/desktop/ui/gui_orchestration.rs",
        "shell/desktop/ui/gui_orchestration_tests.rs",
        "shell/desktop/workbench/tile_render_pass.rs",
        "shell/desktop/tests/scenarios/input_routing.rs"
      ],
      "commands": [
        "cargo test headed_window::tests::test_graph_control_shortcut",
        "cargo test --features diagnostics cycle_focus_region"
      ]
    },
    {
      "id": "input-routing",
      "description": "Scenario-level input routing conformance bundle",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/tests/scenarios/input_routing.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test shell::desktop::tests::scenarios::input_routing:: -- --nocapture"
      ]
    },
    {
      "id": "navigation-history",
      "description": "Scenario-level navigation/history callback ordering and traversal semantics",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "graph_app.rs",
        "shell/desktop/tests/harness.rs",
        "shell/desktop/tests/scenarios/navigation.rs",
        "shell/desktop/tests/scenarios/mod.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test shell::desktop::tests::scenarios::navigation:: -- --nocapture"
      ]
    },
    {
      "id": "registries-scenario",
      "description": "Targeted registries scenario guard for internal settings URL normalization and viewer selection",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/tests/scenarios/registries.rs",
        "shell/desktop/runtime/registries/",
        "util.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test -q phase0_registry_decision_selects_settings_viewer_for_graphshell_settings_url"
      ]
    },
    {
      "id": "scenarios-binary",
      "description": "tests/scenarios binary target (feature-gated CI canary)",
      "policy": {
        "tiers": [
          "pr-optional",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "tests/scenarios/main.rs",
        "Cargo.toml",
        ".github/workflows/windows-scenarios-test.yml"
      ],
      "commands": [
        "cargo test --features test-utils --test scenarios -- --nocapture"
      ]
    },
    {
      "id": "wry-native-overlay",
      "description": "Wry native overlay suppression and sync scenario checks",
      "policy": {
        "tiers": [
          "pr-optional",
          "nightly"
        ],
        "platforms": [
          "windows"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/workbench/interaction_policy.rs",
        "shell/desktop/workbench/tile_compositor.rs",
        "shell/desktop/workbench/tile_behavior.rs",
        "shell/desktop/runtime/registries/mod.rs",
        "registries/atomic/diagnostics.rs",
        "scripts/dev/test-contracts.json",
        ".github/workflows/windows-scenarios-test.yml"
      ],
      "commands": [
        "cargo test --features wry -q native_overlay_sync_records_visible_true",
        "cargo test --features wry -q native_overlay_sync_records_visible_false_for_hidden_tiles",
        "cargo test --features wry -q suppression_reason_maps_to_expected_channel_ids"
      ]
    },
    {
      "id": "scenarios-full",
      "description": "Full diagnostics harness scenario suite",
      "policy": {
        "tiers": [
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/tests/scenarios/",
        "shell/desktop/tests/harness.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test shell::desktop::tests::scenarios:: -- --nocapture"
      ]
    },
    {
      "id": "smoke-quick",
      "description": "Fast baseline check + targeted UI smoke (Windows lane)",
      "policy": {
        "tiers": [
          "nightly"
        ],
        "platforms": [
          "windows"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "scripts/dev/smoke-matrix.ps1",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1",
        "Cargo.toml"
      ],
      "commands": [
        "pwsh -NoProfile -File scripts/dev/smoke-matrix.ps1 quick"
      ]
    },
    {
      "id": "smoke-quick-unix",
      "description": "Fast baseline check + targeted UI smoke (Linux/macOS lanes)",
      "policy": {
        "tiers": [
          "nightly"
        ],
        "platforms": [
          "linux",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "scripts/dev/smoke-matrix.sh",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1",
        "Cargo.toml"
      ],
      "commands": [
        "bash scripts/dev/smoke-matrix.sh quick"
      ]
    },
    {
      "id": "uxtree-gate",
      "description": "UxTree semantic/presentation/trace boundary + diff-gate contract checks",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/workbench/ux_tree.rs",
        "shell/desktop/workbench/tile_post_render.rs",
        "shell/desktop/runtime/registries/mod.rs",
        "shell/desktop/tests/scenarios/ux_tree.rs",
        "shell/desktop/tests/scenarios/ux_tree_diff_gate.rs",
        "design_docs/graphshell_docs/implementation_strategy/subsystem_ux_semantics/ux_tree_and_probe_spec.md",
        "design_docs/graphshell_docs/implementation_strategy/subsystem_ux_semantics/2026-02-28_ux_contract_register.md",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test -q snapshot_uses_single_canonical_id_space_across_layers",
        "cargo test -q consistency_probe_flags_missing_semantic_id_for_presentation_node",
        "cargo test -q diff_gate_semantic_changes_are_blocking_by_default",
        "cargo test -q diff_gate_presentation_changes_are_informational_by_default",
        "cargo test -q diff_gate_can_promote_presentation_changes_to_blocking",
        "cargo test -q uxtree_snapshot_and_probe_are_healthy_for_selected_node_flow",
        "cargo test -q ux_tree_diff_gate_policy_matches_contract_defaults"
      ]
    },
    {
      "id": "graph-parity-gate",
      "description": "Graph model to UxTree semantic parity checks",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "model/graph/mod.rs",
        "graph/mod.rs",
        "shell/desktop/workbench/ux_tree.rs",
        "shell/desktop/workbench/tile_behavior.rs",
        "shell/desktop/tests/scenarios/graph_parity.rs",
        "shell/desktop/tests/scenarios/mod.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test -q snapshot_projects_graph_nodes_into_semantic_layer",
        "cargo test -q uxtree_graph_semantic_parity_matches_graph_model_count"
      ]
    }
  ]
}
