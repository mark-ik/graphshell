{
  "version": 1,
  "packs": [
    {
      "id": "camera-lock",
      "description": "Camera fit-lock reducer + input + orchestration modal passthrough",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "graph_app.rs",
        "input/mod.rs",
        "render/mod.rs",
        "shell/desktop/ui/gui_orchestration.rs",
        "shell/desktop/ui/gui_orchestration_tests.rs",
        "shell/desktop/tests/scenarios/input_routing.rs"
      ],
      "commands": [
        "cargo test camera_fit_lock",
        "cargo test --features diagnostics modal_is_active"
      ]
    },
    {
      "id": "focus-routing",
      "description": "Host/UI focus routing shortcuts and workbench focus cycle",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/host/headed_window.rs",
        "shell/desktop/ui/gui.rs",
        "shell/desktop/ui/gui_update_coordinator.rs",
        "shell/desktop/ui/gui_orchestration.rs",
        "shell/desktop/ui/gui_orchestration_tests.rs",
        "shell/desktop/workbench/tile_render_pass.rs",
        "shell/desktop/tests/scenarios/input_routing.rs"
      ],
      "commands": [
        "cargo test headed_window::tests::test_graph_control_shortcut",
        "cargo test --features diagnostics cycle_focus_region"
      ]
    },
    {
      "id": "input-routing",
      "description": "Scenario-level input routing conformance bundle",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/tests/scenarios/input_routing.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test shell::desktop::tests::scenarios::input_routing:: -- --nocapture"
      ]
    },
    {
      "id": "navigation-history",
      "description": "Scenario-level navigation/history callback ordering and traversal semantics",
      "policy": {
        "tiers": [
          "pr-required",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "graph_app.rs",
        "shell/desktop/tests/harness.rs",
        "shell/desktop/tests/scenarios/navigation.rs",
        "shell/desktop/tests/scenarios/mod.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test shell::desktop::tests::scenarios::navigation:: -- --nocapture"
      ]
    },
    {
      "id": "scenarios-binary",
      "description": "tests/scenarios binary target (feature-gated CI canary)",
      "policy": {
        "tiers": [
          "pr-optional",
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "tests/scenarios/main.rs",
        "Cargo.toml",
        ".github/workflows/scenarios-test.yml"
      ],
      "commands": [
        "cargo test --features test-utils --test scenarios -- --nocapture"
      ]
    },
    {
      "id": "scenarios-full",
      "description": "Full diagnostics harness scenario suite",
      "policy": {
        "tiers": [
          "nightly"
        ],
        "platforms": [
          "linux",
          "windows",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "shell/desktop/tests/scenarios/",
        "shell/desktop/tests/harness.rs",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1"
      ],
      "commands": [
        "cargo test shell::desktop::tests::scenarios:: -- --nocapture"
      ]
    },
    {
      "id": "smoke-quick",
      "description": "Fast baseline check + targeted UI smoke (Windows lane)",
      "policy": {
        "tiers": [
          "nightly"
        ],
        "platforms": [
          "windows"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "scripts/dev/smoke-matrix.ps1",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1",
        "Cargo.toml"
      ],
      "commands": [
        "pwsh -NoProfile -File scripts/dev/smoke-matrix.ps1 quick"
      ]
    },
    {
      "id": "smoke-quick-unix",
      "description": "Fast baseline check + targeted UI smoke (Linux/macOS lanes)",
      "policy": {
        "tiers": [
          "nightly"
        ],
        "platforms": [
          "linux",
          "macos"
        ],
        "alwaysRun": true
      },
      "matchPaths": [
        "scripts/dev/smoke-matrix.sh",
        "scripts/dev/test-contracts.json",
        "scripts/dev/test-select.ps1",
        "Cargo.toml"
      ],
      "commands": [
        "bash scripts/dev/smoke-matrix.sh quick"
      ]
    }
  ]
}
